#!/usr/bin/env bash
# {{COMPANION_NAME}} — persistent companion for Claude Code.
# Reads the statusLine JSON from stdin and prints a single decorated line.

INPUT=$(cat)

read -r CWD MODEL <<EOF
$(printf '%s' "$INPUT" | python3 -c '
import json, sys, os
try:
    d = json.load(sys.stdin)
except Exception:
    d = {}
cwd = (d.get("workspace") or {}).get("current_dir") or d.get("cwd") or os.getcwd()
home = os.path.expanduser("~")
if cwd.startswith(home):
    cwd = "~" + cwd[len(home):]
model = (d.get("model") or {}).get("display_name") or ""
print(cwd, model)
' 2>/dev/null)
EOF

[ -z "$CWD" ] && CWD="~"
[ -z "$MODEL" ] && MODEL="Claude"

MOODS=(
{{MOODS_BLOCK}}
)
MOOD=${MOODS[$((RANDOM % ${#MOODS[@]}))]}

PURPLE=$'\033[38;5;141m'
DIM=$'\033[2m'
ITAL=$'\033[3m'
RESET=$'\033[0m'

printf '%s{{EMOJI}} {{COMPANION_NAME}}%s %s·%s %s%s%s %s·%s %s%s%s %s·%s %s%s%s' \
  "$PURPLE" "$RESET" \
  "$DIM" "$RESET" \
  "$DIM" "$CWD" "$RESET" \
  "$DIM" "$RESET" \
  "$DIM" "$MODEL" "$RESET" \
  "$DIM" "$RESET" \
  "$ITAL" "$MOOD" "$RESET"
